auths:
  littlewolfacres_v2:
    community: {{ vault_snmp_community }}
    version: 2

  littlewolfacres_v3:
    community: {{ vault_snmp_community }}
    security_level: authNoPriv
    username: {{ vault_snmp_v3_username }}
    password: {{ vault_snmp_v3_password }}
    auth_protocol: SHA
    version: 3

modules:
  if_mib:
    walk:
      - 1.3.6.1.2.1.2.2    # ifTable
      - 1.3.6.1.2.1.31.1.1  # ifXTable (64-bit counters + ifName/ifAlias)

    metrics:
      # ── Interface identity ────────────────────────────────────────────────
      - name: ifDescr
        oid: 1.3.6.1.2.1.2.2.1.2
        type: DisplayString
        help: "Textual description of the interface (e.g. eth0, lo)"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifType
        oid: 1.3.6.1.2.1.2.2.1.3
        type: gauge
        help: "Interface type per IANA ifType"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifSpeed
        oid: 1.3.6.1.2.1.2.2.1.5
        type: gauge
        help: "Nominal interface bandwidth in bits per second (use ifHighSpeed for >1Gbps)"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifHighSpeed
        oid: 1.3.6.1.2.1.31.1.1.1.15
        type: gauge
        help: "Interface bandwidth in units of 1,000,000 bps"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifName
        oid: 1.3.6.1.2.1.31.1.1.1.1
        type: DisplayString
        help: "Textual name of the interface"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifAlias
        oid: 1.3.6.1.2.1.31.1.1.1.18
        type: DisplayString
        help: "Operator-assigned alias for the interface"
        indexes:
          - labelname: ifIndex
            type: gauge

      # ── Admin / Oper status ───────────────────────────────────────────────
      - name: ifAdminStatus
        oid: 1.3.6.1.2.1.2.2.1.7
        type: gauge
        help: "Desired state of the interface: 1=up 2=down 3=testing"
        indexes:
          - labelname: ifIndex
            type: gauge
        enum_values:
          1: "up"
          2: "down"
          3: "testing"

      - name: ifOperStatus
        oid: 1.3.6.1.2.1.2.2.1.8
        type: gauge
        help: "Current operational state: 1=up 2=down 3=testing 4=unknown 5=dormant 6=notPresent 7=lowerLayerDown"
        indexes:
          - labelname: ifIndex
            type: gauge
        enum_values:
          1: "up"
          2: "down"
          3: "testing"
          4: "unknown"
          5: "dormant"
          6: "notPresent"
          7: "lowerLayerDown"

      # ── Traffic counters (32-bit — use ifHC* for high-speed links) ────────
      - name: ifInOctets
        oid: 1.3.6.1.2.1.2.2.1.10
        type: counter
        help: "Total octets received, including framing (32-bit; wraps at ~4GB)"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifOutOctets
        oid: 1.3.6.1.2.1.2.2.1.16
        type: counter
        help: "Total octets transmitted, including framing (32-bit)"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifInUcastPkts
        oid: 1.3.6.1.2.1.2.2.1.11
        type: counter
        help: "Unicast packets delivered to a higher sub-layer"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifOutUcastPkts
        oid: 1.3.6.1.2.1.2.2.1.17
        type: counter
        help: "Unicast packets requested to be transmitted"
        indexes:
          - labelname: ifIndex
            type: gauge

      # ── Error / discard counters ──────────────────────────────────────────
      - name: ifInErrors
        oid: 1.3.6.1.2.1.2.2.1.14
        type: counter
        help: "Inbound packets with errors"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifOutErrors
        oid: 1.3.6.1.2.1.2.2.1.20
        type: counter
        help: "Outbound packets that could not be transmitted due to errors"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifInDiscards
        oid: 1.3.6.1.2.1.2.2.1.13
        type: counter
        help: "Inbound packets discarded even though no errors detected"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifOutDiscards
        oid: 1.3.6.1.2.1.2.2.1.19
        type: counter
        help: "Outbound packets discarded even though no errors detected"
        indexes:
          - labelname: ifIndex
            type: gauge

      # ── 64-bit (HC) traffic counters — use these for 1Gbps+ links ────────
      - name: ifHCInOctets
        oid: 1.3.6.1.2.1.31.1.1.1.6
        type: counter
        help: "Total octets received (64-bit; preferred on high-speed links)"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifHCOutOctets
        oid: 1.3.6.1.2.1.31.1.1.1.10
        type: counter
        help: "Total octets transmitted (64-bit)"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifHCInUcastPkts
        oid: 1.3.6.1.2.1.31.1.1.1.7
        type: counter
        help: "Unicast packets received (64-bit)"
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifHCOutUcastPkts
        oid: 1.3.6.1.2.1.31.1.1.1.11
        type: counter
        help: "Unicast packets transmitted (64-bit)"
        indexes:
          - labelname: ifIndex
            type: gauge

version: 2
