groups:
  - name: homelab
    interval: 1m
    rules:

      # ── Watchtower host ──────────────────────────────────────────────────────

      - alert: WatchtowerHighCPU
        expr: 100 - (avg(rate(node_cpu_seconds_total{mode="idle",instance="watchtower"}[5m])) * 100) > 85
        for: 5m
        labels:
          severity: warning
          host: watchtower
        annotations:
          description: "Watchtower CPU usage is above 85% for 5 minutes (current: {{ "{{" }} $value | printf \"%.1f\" {{ "}}" }}%)"

      - alert: WatchtowerHighMemory
        expr: (1 - (node_memory_MemAvailable_bytes{instance="watchtower"} / node_memory_MemTotal_bytes{instance="watchtower"})) * 100 > 85
        for: 5m
        labels:
          severity: warning
          host: watchtower
        annotations:
          description: "Watchtower memory usage is above 85% for 5 minutes (current: {{ "{{" }} $value | printf \"%.1f\" {{ "}}" }}%)"

      - alert: WatchtowerLowDisk
        expr: (1 - (node_filesystem_avail_bytes{instance="watchtower",mountpoint="/"} / node_filesystem_size_bytes{instance="watchtower",mountpoint="/"})) * 100 > 80
        for: 10m
        labels:
          severity: warning
          host: watchtower
        annotations:
          description: "Watchtower disk usage is above 80% (current: {{ "{{" }} $value | printf \"%.1f\" {{ "}}" }}%) — investigate before it climbs further"

      - alert: WatchtowerCriticalDisk
        expr: (1 - (node_filesystem_avail_bytes{instance="watchtower",mountpoint="/"} / node_filesystem_size_bytes{instance="watchtower",mountpoint="/"})) * 100 > 90
        for: 5m
        labels:
          severity: critical
          host: watchtower
        annotations:
          description: "Watchtower disk usage is above 90% (current: {{ "{{" }} $value | printf \"%.1f\" {{ "}}" }}%) — immediate action required"

      - alert: WatchtowerPrometheusDown
        expr: up{job="prometheus"} == 0
        for: 2m
        labels:
          severity: critical
          host: watchtower
        annotations:
          description: "Prometheus on Watchtower is unreachable — all metric-based alerts are unreliable until it recovers"

      - alert: WatchtowerPrometheusTSDB
        expr: prometheus_tsdb_storage_blocks_bytes{job="prometheus",instance="watchtower"} > 8e9
        for: 15m
        labels:
          severity: warning
          host: watchtower
        annotations:
          description: "Prometheus TSDB block storage is above 8GB (current: {{ "{{" }} $value | humanize {{ "}}" }}B) — approaching 10GB retention limit. Expect compaction to temporarily spike disk, CPU, and memory."

      - alert: WatchtowerNodeExporterDown
        expr: up{job="watchtower"} == 0
        for: 1m
        labels:
          severity: critical
          host: watchtower
        annotations:
          description: "Watchtower node_exporter is down — host metrics unavailable"

      - alert: AdGuardHomeDown
        expr: up{job="adguard"} == 0
        for: 1m
        labels:
          severity: critical
          host: watchtower
        annotations:
          description: "AdGuard Home is down — DNS filtering may be affected"

      # ── Monolith host ────────────────────────────────────────────────────────

      - alert: MonolithDown
        expr: up{job="monolith"} == 0
        for: 1m
        labels:
          severity: critical
          host: monolith
        annotations:
          description: "Monolith is unreachable — node_exporter scrape failed. k3s workloads may be affected."

      - alert: MonolithHighCPU
        expr: 100 - (avg(rate(node_cpu_seconds_total{mode="idle",job="monolith"}[5m])) * 100) > 85
        for: 5m
        labels:
          severity: warning
          host: monolith
        annotations:
          description: "Monolith CPU usage is above 85% for 5 minutes (current: {{ "{{" }} $value | printf \"%.1f\" {{ "}}" }}%)"

      - alert: MonolithHighMemory
        expr: (1 - (node_memory_MemAvailable_bytes{job="monolith"} / node_memory_MemTotal_bytes{job="monolith"})) * 100 > 85
        for: 5m
        labels:
          severity: warning
          host: monolith
        annotations:
          description: "Monolith memory usage is above 85% for 5 minutes (current: {{ "{{" }} $value | printf \"%.1f\" {{ "}}" }}%)"

      - alert: MonolithLowDisk
        expr: (1 - (node_filesystem_avail_bytes{job="monolith",mountpoint="/"} / node_filesystem_size_bytes{job="monolith",mountpoint="/"})) * 100 > 80
        for: 5m
        labels:
          severity: critical
          host: monolith
        annotations:
          description: "Monolith disk usage on / is above 80% (current: {{ "{{" }} $value | printf \"%.1f\" {{ "}}" }}%)"

      - alert: MonolithLowDiskHddC
        expr: (1 - (node_filesystem_avail_bytes{job="monolith",mountpoint="/mnt/hdd-c"} / node_filesystem_size_bytes{job="monolith",mountpoint="/mnt/hdd-c"})) * 100 > 80
        for: 5m
        labels:
          severity: critical
          host: monolith
        annotations:
          description: "Monolith disk usage on /mnt/hdd-c (music/bulk) is above 80% (current: {{ "{{" }} $value | printf \"%.1f\" {{ "}}" }}%)"

      - alert: MonolithLowDiskHddD
        expr: (1 - (node_filesystem_avail_bytes{job="monolith",mountpoint="/mnt/hdd-d"} / node_filesystem_size_bytes{job="monolith",mountpoint="/mnt/hdd-d"})) * 100 > 80
        for: 5m
        labels:
          severity: warning
          host: monolith
        annotations:
          description: "Monolith disk usage on /mnt/hdd-d (mirror) is above 80% (current: {{ "{{" }} $value | printf \"%.1f\" {{ "}}" }}%)"
