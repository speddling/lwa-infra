global:
  scrape_interval: 15s
  evaluation_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets: ['localhost:{{ port_alertmanager }}']

rule_files:
  - /etc/prometheus/alert_rules.yml

scrape_configs:
  - job_name: 'watchtower'
    static_configs:
      - targets: ['localhost:{{ port_node_exporter }}']
    # Relabel instance from localhost:9100 → watchtower so Grafana dashboards
    # (e.g. Node Exporter Full, ID 1860) display a meaningful hostname in
    # the $node variable, and alert rules can filter by name rather than address.
    relabel_configs:
      - target_label: instance
        replacement: watchtower

  - job_name: 'blackbox'
    static_configs:
      - targets: ['localhost:{{ port_blackbox_exporter }}']

  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ port_prometheus }}']
    relabel_configs:
      - target_label: instance
        replacement: watchtower

  - job_name: 'adguard'
    static_configs:
      - targets: ['localhost:{{ port_adguard_exporter }}']

  - job_name: 'monolith'
    static_configs:
      # Static label pins the instance name to 'monolith' so dashboards and
      # alert rules are consistent regardless of FQDN changes.
      - targets: ['{{ fqdn_monolith }}:{{ port_node_exporter }}']
        labels:
          instance: monolith

  # ── Blackbox probes ──────────────────────────────────────────────────────
  # Each job uses the blackbox exporter as a proxy to probe a target.
  # probe_success{instance="..."} is the key metric — 1=up, 0=down.
  # Add targets here; the Blackbox Exporter dashboard (ID 7587) reads them.

  - job_name: 'blackbox-http'
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - 'http://{{ fqdn_grafana }}:{{ port_grafana }}'
          - 'http://{{ fqdn_navidrome }}'
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: localhost:{{ port_blackbox_exporter }}

  - job_name: 'blackbox-icmp'
    metrics_path: /probe
    params:
      module: [icmp]
    static_configs:
      - targets:
          - '{{ ip_monolith }}'
          - '{{ ip_watchtower }}'
          - '1.1.1.1'
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: localhost:{{ port_blackbox_exporter }}

  # ── SNMP ─────────────────────────────────────────────────────────────────

  - job_name: 'snmp-er605'
    static_configs:
      - targets: ['{{ ip_er605 }}']
    metrics_path: /snmp
    params:
      module: [if_mib]
      auth: ['{{ snmp_auth_module }}']
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: localhost:{{ port_snmp_exporter }}

  - job_name: 'snmp-eap-yarn-studio'
    static_configs:
      - targets: ['{{ ip_eap245_yarn_studio }}']
    metrics_path: /snmp
    params:
      module: [if_mib]
      auth: ['{{ snmp_auth_module }}']
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: localhost:{{ port_snmp_exporter }}

  - job_name: 'snmp-eap-foyer'
    static_configs:
      - targets: ['{{ ip_eap245_foyer }}']
    metrics_path: /snmp
    params:
      module: [if_mib]
      auth: ['{{ snmp_auth_module }}']
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: localhost:{{ port_snmp_exporter }}

  # ── Uncomment when SG2218P and EAP225-Outdoor are installed ──────────────
  # Set ip_sg2218p and ip_eap225_outdoor in ansible/vars/main.yml first.

  # - job_name: 'snmp-sg2218p'
  #   static_configs:
  #     - targets: ['{{ ip_sg2218p }}']
  #   metrics_path: /snmp
  #   params:
  #     module: [if_mib]
  #     auth: ['{{ snmp_auth_module }}']
  #   relabel_configs:
  #     - source_labels: [__address__]
  #       target_label: __param_target
  #     - source_labels: [__param_target]
  #       target_label: instance
  #     - target_label: __address__
  #       replacement: localhost:{{ port_snmp_exporter }}

  # - job_name: 'snmp-eap-outdoor'
  #   static_configs:
  #     - targets: ['{{ ip_eap225_outdoor }}']
  #   metrics_path: /snmp
  #   params:
  #     module: [if_mib]
  #     auth: ['{{ snmp_auth_module }}']
  #   relabel_configs:
  #     - source_labels: [__address__]
  #       target_label: __param_target
  #     - source_labels: [__param_target]
  #       target_label: instance
  #     - target_label: __address__
  #       replacement: localhost:{{ port_snmp_exporter }}

  - job_name: 'tmobile'
    static_configs:
      - targets: ['localhost:{{ port_tmobile_exporter }}']

  # ── WAN2 placeholder ─────────────────────────────────────────────────────
  # Uncomment and set ip_att_gateway once AT&T Internet Air is installed.
  # Monitor at the ER605 SNMP level; CGW450 has no unauthenticated API.
  # - job_name: 'snmp-att-cgw450'
  #   static_configs:
  #     - targets: ['{{ ip_att_gateway | default("192.168.1.1") }}']
  #   metrics_path: /snmp
  #   params:
  #     module: [if_mib]
  #     auth: ['{{ snmp_auth_module }}']
  #   relabel_configs:
  #     - source_labels: [__address__]
  #       target_label: __param_target
  #     - source_labels: [__param_target]
  #       target_label: instance
  #     - target_label: __address__
  #       replacement: localhost:{{ port_snmp_exporter }}

  - job_name: 'reolink_nvr'
    static_configs:
      - targets: ['localhost:{{ port_reolink_exporter }}']

  # ── k3s / Monolith ───────────────────────────────────────────────────────

  - job_name: 'kube-state-metrics'
    static_configs:
      - targets: ['{{ fqdn_monolith }}:{{ port_kube_state_metrics }}']

  # ── ArgoCD ──────────────────────────────────────────────────────────────
  # application-controller: app health, sync status, reconciliation counts
  # argocd-server:          API/UI availability and latency
  # Both exposed via NodePort since Prometheus is external to k3s.

  - job_name: 'argocd-app-controller'
    static_configs:
      - targets: ['{{ fqdn_monolith }}:{{ port_argocd_metrics_controller }}']
    relabel_configs:
      - target_label: instance
        replacement: argocd

  - job_name: 'argocd-server'
    static_configs:
      - targets: ['{{ fqdn_monolith }}:{{ port_argocd_metrics_server }}']
    relabel_configs:
      - target_label: instance
        replacement: argocd

  # ── Loki / Promtail ──────────────────────────────────────────────────────

  - job_name: 'loki'
    static_configs:
      - targets: ['localhost:{{ port_loki }}']
    relabel_configs:
      - target_label: instance
        replacement: watchtower

  - job_name: 'promtail'
    static_configs:
      - targets: ['localhost:{{ port_promtail }}']
    relabel_configs:
      - target_label: instance
        replacement: watchtower

  # ── Obelisk ─────────────────────────────────────────────────────────────
  # windows_exporter running inside the Win11 VM, exposed via NodePort.
  # Only active when the VM is running — scrape failures are expected when off.

  - job_name: 'obelisk'
    static_configs:
      - targets: ['{{ fqdn_monolith }}:{{ port_obelisk_metrics }}']
        labels:
          instance: obelisk
