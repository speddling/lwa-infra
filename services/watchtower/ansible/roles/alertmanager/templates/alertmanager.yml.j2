global:
  resolve_timeout: {{ alertmanager_resolve_timeout }}
  slack_api_url: '{{ vault_slack_webhook_url }}'

route:
  group_by: ['alertname', 'severity']
  group_wait: {{ alertmanager_group_wait }}
  group_interval: {{ alertmanager_group_interval }}
  repeat_interval: {{ alertmanager_repeat_interval }}
  receiver: sentinel

receivers:
  - name: sentinel
    slack_configs:
      - channel: '{{ alertmanager_slack_channel }}'
        username: '{{ alertmanager_slack_username }}'
        icon_emoji: '{{ alertmanager_slack_icon }}'
        send_resolved: true
        title: '{{ "{{" }} if eq .Status "firing" {{ "}}" }}🔴 {{ "{{" }} else {{ "}}" }}✅ {{ "{{" }} end {{ "}}" }}{{ "{{" }} .CommonLabels.alertname {{ "}}" }}'
        text: |
          {{ "{{" }} range .Alerts {{ "}}" }}
          *Status:* {{ "{{" }} .Status | toUpper {{ "}}" }}
          *Description:* {{ "{{" }} .Annotations.description {{ "}}" }}
          *Severity:* {{ "{{" }} .Labels.severity {{ "}}" }}
          {{ "{{" }} end {{ "}}" }}

inhibit_rules:
  # Suppress warnings when a critical fires for the same rule
  - source_matchers:
      - severity = critical
    target_matchers:
      - severity = warning
    equal: ['alertname']
  # Suppress all Watchtower threshold alerts when Prometheus itself is down —
  # metric-based alerts are unreliable and would otherwise fire as a cascade
  - source_matchers:
      - alertname = WatchtowerPrometheusDown
    target_matchers:
      - host = watchtower
    equal: ['host']
