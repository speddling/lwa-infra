server:
  http_listen_port: {{ port_promtail }}
  grpc_listen_port: 0
  log_level: warn

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: http://localhost:{{ port_loki }}/loki/api/v1/push

scrape_configs:

  # ── Watchtower systemd journal ────────────────────────────────────────────
  # Captures all unit logs: tmobile_exporter errors, daily-summary runs,
  # alertmanager/prometheus events, reolink_exporter, argus, etc.
  - job_name: watchtower-journal
    journal:
      max_age: 12h
      labels:
        job: watchtower-journal
        host: watchtower
    relabel_configs:
      - source_labels: [__journal__systemd_unit]
        target_label: unit
      - source_labels: [__journal__priority_keyword]
        target_label: level

  # ── Network device syslog receiver ────────────────────────────────────────
  # Shared UDP listener for any network device's syslog stream — ER605
  # (WAN up/down, DHCP lease events, failover triggers) and Omada
  # Controller (device join/leave, config changes, alerts, the "log
  # storage near limit" class of system event). Devices are NOT split
  # into separate jobs/ports — the hostname relabel below distinguishes
  # them automatically from the syslog message itself.
  #
  # protocol: udp is explicit and required — Promtail's syslog stage
  # defaults to TCP, but neither the ER605 nor Omada Controller's remote
  # logging supports anything but UDP. Without this line the listener
  # silently receives nothing from either source.
  #
  # Configure ER605: System → Syslog → Remote Server → {{ ip_watchtower }}:{{ port_promtail_syslog }}
  # Configure Omada Controller: Site Settings → Log Settings → Enable
  #   Server → {{ ip_watchtower }}:{{ port_promtail_syslog }}
  - job_name: network-syslog
    syslog:
      listen_address: 0.0.0.0:{{ port_promtail_syslog }}
      protocol: udp
      idle_timeout: 60s
      label_structured_data: true
      labels:
        job: network-syslog
    relabel_configs:
      - source_labels: [__syslog_message_hostname]
        target_label: hostname
      - source_labels: [__syslog_message_app_name]
        target_label: app
      - source_labels: [__syslog_message_severity]
        target_label: level
