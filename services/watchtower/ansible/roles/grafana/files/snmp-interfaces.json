{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Network interface traffic, errors and status for ER605 router and EAP245 access points via SNMP (if_mib).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Interface Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "color": "green", "text": "Up" }, "2": { "color": "red", "text": "Down" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" },
          "custom": { "displayMode": "color-background" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "displayMode": "table",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "ifOperStatus{job=~\"snmp-.*\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} — {{ifDescr}}",
          "refId": "A"
        }
      ],
      "title": "Interface Operational Status",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "custom.transform", "value": "negative-Y" }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "rate(ifHCInOctets{job=~\"snmp-.*\", instance=~\"$device\"}[$__rate_interval]) * 8",
          "legendFormat": "▲ {{instance}} {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "rate(ifHCOutOctets{job=~\"snmp-.*\", instance=~\"$device\"}[$__rate_interval]) * 8",
          "legendFormat": "▼ {{instance}} {{ifDescr}}",
          "refId": "B"
        }
      ],
      "title": "Interface Bandwidth (In ▲ / Out ▼)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "Errors & Discards",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "rate(ifInErrors{job=~\"snmp-.*\", instance=~\"$device\"}[$__rate_interval])",
          "legendFormat": "In Errors — {{instance}} {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "rate(ifOutErrors{job=~\"snmp-.*\", instance=~\"$device\"}[$__rate_interval])",
          "legendFormat": "Out Errors — {{instance}} {{ifDescr}}",
          "refId": "B"
        }
      ],
      "title": "Interface Errors",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "rate(ifInDiscards{job=~\"snmp-.*\", instance=~\"$device\"}[$__rate_interval])",
          "legendFormat": "In Discards — {{instance}} {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "rate(ifOutDiscards{job=~\"snmp-.*\", instance=~\"$device\"}[$__rate_interval])",
          "legendFormat": "Out Discards — {{instance}} {{ifDescr}}",
          "refId": "B"
        }
      ],
      "title": "Interface Discards",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["snmp", "network", "homelab"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "definition": "label_values(ifOperStatus{job=~\"snmp-.*\"}, instance)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "device",
        "options": [],
        "query": {
          "query": "label_values(ifOperStatus{job=~\"snmp-.*\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "label": "Device",
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SNMP — Network Interfaces",
  "uid": "lwa-snmp-interfaces",
  "version": 1
}
