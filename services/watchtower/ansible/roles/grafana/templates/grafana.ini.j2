[server]
http_addr = 0.0.0.0
http_port = 3001
domain = grafana.local
root_url = http://grafana.local:3001

[security]
admin_user = admin
admin_password = {{ vault_grafana_password }}
secret_key = {{ vault_grafana_secret_key }}
disable_gravatar = true

[users]
allow_sign_up = false
allow_org_create = false

[auth.anonymous]
enabled = false

[unified_alerting]
enabled = true

[log]
mode = console
level = warn
