[server]
http_addr = 0.0.0.0
http_port = 3001
domain = grafana.local
root_url = http://grafana.local:3001

[security]
admin_user = admin
admin_password = {{ vault_grafana_password }}
secret_key = {{ vault_grafana_secret_key }}
disable_gravatar = true

[users]
allow_sign_up = false
allow_org_create = false

[auth.anonymous]
enabled = false

[unified_alerting]
# Disabled — alerting is owned by Prometheus + Alertmanager.
# Grafana is display-only. Enabling this causes DatasourceNoData
# state alerts to fire via the Grafana contact point, duplicating
# and racing with the Alertmanager → Slack pipeline.
enabled = false

[alerting]
# Legacy alerting also disabled for the same reason.
enabled = false

[log]
mode = console
level = warn
