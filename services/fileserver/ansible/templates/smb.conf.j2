[global]
   workgroup = WORKGROUP
   server string = Monolith File Server
   server role = standalone server
   log file = /var/log/samba/log.%m
   max log size = 50
   dns proxy = no

   # Security
   security = user
   map to guest = never
   smb encrypt = desired

[{{ vault_share_name }}]
   comment = Vault — Family backup share
   path = {{ vault_share_path }}
   browseable = yes
   read only = no
   valid users = {{ samba_user }}
   create mask = 0664
   directory mask = 0775
   force user = {{ samba_user }}

[{{ studio_share_name }}]
   comment = Studio Archive — DAW project storage
   path = {{ studio_share_path }}
   browseable = yes
   read only = no
   valid users = {{ james_user }}
   create mask = 0660
   directory mask = 0770
   force user = {{ james_user }}

[{{ music_share_name }}]
   comment = Music Library — Navidrome source / metadata editing
   path = {{ music_share_path }}
   browseable = yes
   read only = no
   valid users = {{ james_user }}
   create mask = 0664
   directory mask = 0775
   force user = {{ james_user }}
