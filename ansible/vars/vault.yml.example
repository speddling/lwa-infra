# =============================================================================
# ansible/vars/vault.yml.example
# =============================================================================
# Template showing every secret variable name used across the homelab.
# DO NOT commit the real vault.yml in plaintext.
#
# To create the consolidated vault:
#
#   1. Decrypt existing per-service vaults to extract current values:
#        ansible-vault decrypt services/watchtower/ansible/group_vars/all/vault.yml --output=/tmp/wt-vault.yml
#        ansible-vault decrypt services/fileserver/ansible/group_vars/all/vault.yml --output=/tmp/fs-vault.yml
#
#   2. Copy this file and fill in the real values:
#        cp ansible/vars/vault.yml.example ansible/vars/vault.yml
#        # edit ansible/vars/vault.yml with real secrets
#
#   3. Encrypt the consolidated vault:
#        ansible-vault encrypt ansible/vars/vault.yml
#
#   4. Remove the old per-service vault files:
#        rm services/watchtower/ansible/group_vars/all/vault.yml
#        rm services/fileserver/ansible/group_vars/all/vault.yml
#
#   5. Clean up temp files:
#        rm /tmp/wt-vault.yml /tmp/fs-vault.yml
# =============================================================================

# Alertmanager → Slack
vault_slack_webhook_url: "https://hooks.slack.com/services/REPLACE_ME"

# Samba (fileserver)
vault_samba_password: "REPLACE_ME"
vault_james_password: "REPLACE_ME"

# NUT UPS monitor user
vault_nut_monitor_password: "REPLACE_ME"

# Reolink NVR admin password
vault_reolink_nvr_password: "REPLACE_ME"

# SNMP (community string stored in vault for snmp_exporter)
vault_snmp_community: "REPLACE_ME"

# Omada Open API (Settings → Platform Integration → Open API, Client Credentials app)
# Client ID + Omada ID + Interface Access Address are low-sensitivity; secret is not.
# api_base uses the CURRENT controller address pre-cutover so the read-only export
# can be proven before the network change. At cutover, change ONLY this line to the
# new Mgmt-VLAN address (https://192.168.10.3:443). Credentials do not change.
# NOTE: the controller's real current address is .0.7 (confirmed on SG2218P port 11);
# the Open API "Interface Access Address" field misreported .0.3 during bring-up.
vault_omada_client_id:     "REPLACE_ME"
vault_omada_client_secret: "REPLACE_ME"
vault_omada_id:            "REPLACE_ME"
vault_omada_api_base:      "https://192.168.0.7:443"

# ArgoCD — GitHub PAT for homelab repo access
# Fine-grained PAT: single repo scope, Contents: Read, no expiration recommended.
# Rotated via: Actions → Rotate ArgoCD Credentials → Run workflow
vault_argocd_github_token: "REPLACE_ME"

# Slack — Zombatron Importer bot
# Bot token:     OAuth & Permissions → Bot Token (xoxb-)
# App token:     Basic Information → App-Level Tokens → connections:write (xapp-)
# Signing secret: Basic Information → Signing Secret
vault_slack_zombatron_bot_token:      "xoxb-REPLACE_ME"
vault_slack_zombatron_signing_secret: "REPLACE_ME"
vault_slack_zombatron_app_token:      "xapp-REPLACE_ME"

# Obelisk — Windows 11 VM local accounts
# Both accounts are Administrators. obelisk is the client-facing account.
vault_obelisk_admin_password:    "REPLACE_ME"
vault_speddling_obelisk_password: "REPLACE_ME"

# Healthchecks.io — dead-man's switch for daily summary pipeline
# Create a check at healthchecks.io: period=12h, grace=1h
# Paste the ping URL here (https://hc-ping.com/<uuid>)
vault_healthchecks_daily_summary_url: "https://hc-ping.com/REPLACE_ME"

# Healthchecks.io — dead-man's switch for Alertmanager (Watchtower heartbeat)
# Create a SEPARATE check at healthchecks.io: period=5m, grace=15m
# If pings stop, healthchecks.io emails you regardless of Slack/WAN state.
# Paste the ping URL here (https://hc-ping.com/<uuid>)
vault_healthchecks_watchdog_url: "https://hc-ping.com/REPLACE_ME"

# GitHub — Fine-grained PAT for Zombatron Importer workflow dispatch
# Scopes: Actions: Read & Write (single repo: speddling/lwa-homelab)
vault_github_actions_pat: "github_pat_REPLACE_ME"

# Plane (self-hosted project tracker) — no Ansible Vault entries needed.
# All of Plane's runtime secrets (Postgres, RabbitMQ, MinIO, app SECRET_KEY)
# are generated fresh by .github/workflows/bootstrap-plane.yml and exist
# only as Kubernetes Secret objects in the plane namespace. Re-run that
# workflow to generate new ones if the namespace is ever rebuilt —
# there's no prior value to recover from this vault.
